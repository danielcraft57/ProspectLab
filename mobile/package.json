{
  "name": "mobile",
  "version": "1.3.0",
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "node scripts/ensure-react-native-touch-header.cjs && patch-package",
    "icons": "python scripts/generate_app_icons.py",
    "start": "node scripts/start-expo-dev.cjs",
    "start:tunnel": "node scripts/start-expo-dev.cjs --tunnel",
    "android": "node scripts/run-expo-android.cjs",
    "android:install-apk": "node scripts/install-debug-apk.cjs",
    "build:android:local:release": "cd android && gradlew.bat assembleRelease",
    "android:install-release-apk": "node scripts/install-release-apk.cjs",
    "android:local-release": "npm run build:android:local:release && npm run android:install-release-apk",
    "build:android:internal": "npx eas-cli build -p android --profile internal",
    "build:android:prod": "npx eas-cli build -p android --profile production",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-dev-launcher": "^6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-viewing": "^0.2.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "patch-package": "^8.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
