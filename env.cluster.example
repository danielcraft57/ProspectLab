# Configuration pour utiliser le cluster (node15 = Redis + Postgres) depuis ta machine locale
# Copiez ce fichier en .env.cluster et adaptez les valeurs (host, mot de passe).
# Puis lancez l'app avec: .\scripts\run_local_use_cluster.ps1
# Les tâches Celery seront exécutées par les workers du cluster (node15, node13, node14).

# ============================================
# Redis / Celery (obligatoire pour le cluster)
# ============================================
# Redis sur le master du cluster (node15) - doit être accessible sur le LAN
CELERY_BROKER_URL=redis://mon_serveur:6379/1
CELERY_RESULT_BACKEND=redis://mon_serveur:6379/1
CELERY_WORKERS=0

# ============================================
# Fichiers (uploads) en mode cluster
# ============================================
# Quand l'app tourne sur Windows et les workers sur Linux, les workers ne peuvent pas lire un chemin C:\...
# Donc on copie le fichier uploadé vers chaque worker avant d'enfiler la tâche d'analyse.
CLUSTER_WORKER_NODES=node13.lan,node14.lan
CLUSTER_WORKER_USER=pi
CLUSTER_REMOTE_PATH=/opt/prospectlab

# ============================================
# Base de données (optionnel)
# ============================================
# Si tu veux utiliser la même BDD que le cluster (Postgres sur node15), décommente et adapte :
# DATABASE_URL=postgresql://prospectlab:VOTRE_MOT_DE_PASSE@mon_serveur:5432/prospectlab
# Sinon, laisse vide ou utilise DATABASE_PATH pour une SQLite locale (données séparées du cluster).

# ============================================
# Reste des variables
# ============================================
# Tu peux garder le reste comme dans ton .env (SECRET_KEY, MAIL_*, APIs, etc.)
# Ce fichier peut être fusionné avec .env : seules CELERY_* et éventuellement DATABASE_URL changent.
