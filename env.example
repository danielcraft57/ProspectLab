# Configuration ProspectLab
# Copiez ce fichier en .env puis adaptez les valeurs.

# ============================================
# Application / securite
# ============================================
APP_ENV=development
FLASK_DEBUG=0
# Genere une vraie cle avant production:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# ============================================
# Base de donnees
# ============================================
# SQLite (local)
DATABASE_PATH=prospectlab.db
# PostgreSQL (prod): prioritaire sur DATABASE_PATH si active
# DATABASE_URL=postgresql://prospectlab:password@localhost:5432/prospectlab

# ============================================
# Redis / Celery
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKERS=4

# ============================================
# Email (SMTP)
# ============================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-mot-de-passe-app
MAIL_DEFAULT_SENDER="Votre Nom <votre-email@gmail.com>"
MAIL_DEFAULT_RECIPIENT="contact@votre-domaine.com"

# Base URL utilisee pour tracking (liens/pixels)
# En prod: mettre un domaine public HTTPS
BASE_URL=http://localhost:5000

# ============================================
# API Sirene
# ============================================
SIRENE_API_URL=https://recherche-entreprises.api.gouv.fr/search
SIRENE_API_RATE_LIMIT=10
# SIRENE_API_KEY=votre-cle-api-sirene

# ============================================
# APIs OSINT / enrichissement
# ============================================
SHODAN_API_KEY=votre-cle-api-shodan
CENSYS_API_ID=votre-censys-api-id
CENSYS_API_SECRET=votre-censys-api-secret
HUNTER_API_KEY=votre-cle-api-hunter
BUILTWITH_API_KEY=votre-cle-api-builtwith
HIBP_API_KEY=votre-cle-api-hibp

# ============================================
# Google Maps
# ============================================
GOOGLE_MAPS_JS_API_KEY=votre-cle-google-maps-js

# ============================================
# Multicanal - X (Twitter)
# ============================================
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ============================================
# Multicanal - Meta Messenger
# ============================================
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v20.0

# ============================================
# WSL / outils externes
# ============================================
WSL_DISTRO=kali-linux
WSL_USER=loupix
OSINT_TOOL_TIMEOUT=60
PENTEST_TOOL_TIMEOUT=120

