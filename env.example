# Configuration ProspectLab
# Copiez ce fichier en .env puis adaptez les valeurs.

# ============================================
# Application / securite
# ============================================
APP_ENV=development
FLASK_DEBUG=0
# Genere une vraie cle avant production:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# ============================================
# Base de donnees
# ============================================
# SQLite (local)
DATABASE_PATH=prospectlab.db
# PostgreSQL (prod): prioritaire sur DATABASE_PATH si active
# DATABASE_URL=postgresql://prospectlab:password@localhost:5432/prospectlab

# ============================================
# Redis / Celery
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKERS=4

# Files Celery à consommer (défaut si absent dans .env côté code: inclut aussi les queues dédiées)
# scraping_interactive : relances UI/WebSocket (prioritaire vs gros lots sur `scraping`)
# Si tu n'écoutes que `celery,heavy`, les tâches routées sur `scraping/technical/seo/osint/pentest`
# ne seront jamais exécutées et tu verras "aucun log".
CELERY_WORKER_QUEUES=celery,scraping,scraping_interactive,technical,seo,osint,pentest,heavy,website_full
# Option cluster (script Linux) : CELERY_WORKER_QUEUE_PRESET=scraping_only | non_scraping (voir start_celery_worker.sh)

# Pack « analyse site complet » : file d’enqueue (défaut : technical — même file que les analyses lourdes)
# Pour un worker dédié uniquement au pack : CELERY_FULL_ANALYSIS_QUEUE=website_full (+ website_full dans CELERY_WORKER_QUEUES)
# CELERY_FULL_ANALYSIS_QUEUE=technical

# Scraping : 0 (défaut) = parallèle selon le worker Celery. 1 = verrou global Redis (un scrape à la fois).
# SCRAPING_GLOBAL_LOCK_ENABLED=0
# SCRAPING_LOCK_RETRY_SEC=10
# SCRAPING_LOCK_WAIT_MAX_SEC=86400
# Orchestrateur scraping d'analyse (scrape_analysis_orchestrator_task)
# SCRAPE_ANALYSIS_BATCH_SIZE=20
# SCRAPE_ANALYSIS_BATCH_RETRY_MAX=1

# ============================================
# Email (SMTP)
# ============================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-mot-de-passe-app
MAIL_DEFAULT_SENDER="Votre Nom <votre-email@gmail.com>"
MAIL_DEFAULT_RECIPIENT="contact@votre-domaine.com"

# ============================================
# Boite mail (IMAP) - récupération des bounces
# ============================================
# La boite qui reçoit les retours "Undelivered / Mail delivery failed".
# Utilisé par scripts/fetch_bounces_imap.py (support multi-profils)
# IMAP_HOST=imap.votre-domaine.com
# IMAP_PORT=993
# IMAP_SSL=true
# IMAP_USERNAME=votre-email@gmail.com
# IMAP_PASSWORD=votre-mot-de-passe
# IMAP_MAILBOX=INBOX
# IMAP_SINCE_DAYS=14
#
# Pour gérer plusieurs boites:
# - définir IMAP_PROFILES=gmail,domain
# - puis fournir les variables suffixées:
#   IMAP_HOST_GMAIL=imap.gmail.com
#   IMAP_USERNAME_GMAIL=...
#   IMAP_PASSWORD_GMAIL=...
#   IMAP_MAILBOX_GMAIL=INBOX
#   IMAP_HOST_DOMAIN=imap.votre-domaine.com
#   IMAP_PORT_DOMAIN=993
#   IMAP_SSL_DOMAIN=true
#   IMAP_USERNAME_DOMAIN=contact
#   IMAP_PASSWORD_DOMAIN=...
#   IMAP_MAILBOX_DOMAIN=INBOX
#
# Scan bounces automatique (Celery)
# true = active la tâche auto (après lancement campagne + 2x/jour via beat)
BOUNCE_SCAN_ENABLED=true
# Profils IMAP à scanner (doit correspondre à IMAP_PROFILES)
BOUNCE_SCAN_PROFILES=default
# Fenêtre de scan périodique (jours)
BOUNCE_SCAN_DAYS=14
# Fenêtre de scan du run "post-campagne" (jours)
BOUNCE_SCAN_AFTER_CAMPAIGN_DAYS=2
# 0 = sans limite de messages à scanner, >0 = limite
BOUNCE_SCAN_LIMIT=0
# Supprimer/déplacer les bounces déjà traités en IMAP
BOUNCE_SCAN_DELETE_PROCESSED=true
# Délai après lancement campagne avant le scan auto (secondes)
BOUNCE_SCAN_POST_CAMPAIGN_DELAY_SEC=1800

# Cache-buster assets (JS/CSS) - optionnel
# Change cette valeur à chaque déploiement si tu veux forcer le navigateur à recharger les assets.
# APP_BUILD_ID=20260330-1

# Base URL utilisee pour tracking (liens/pixels)
# En prod: mettre un domaine public HTTPS
BASE_URL=http://localhost:5000

# ============================================
# API Sirene
# ============================================
SIRENE_API_URL=https://recherche-entreprises.api.gouv.fr/search
SIRENE_API_RATE_LIMIT=10
# SIRENE_API_KEY=votre-cle-api-sirene

# ============================================
# APIs OSINT / enrichissement
# ============================================
SHODAN_API_KEY=votre-cle-api-shodan
CENSYS_API_ID=votre-censys-api-id
CENSYS_API_SECRET=votre-censys-api-secret
HUNTER_API_KEY=votre-cle-api-hunter
# Validation email (Abstract) — optionnel, enrichit analyze_email
# ABSTRACT_EMAIL_API_KEY=
# Validation téléphone (Abstract, Numverify/APILayer) — optionnel, enrichit analyze_phones_osint
# ABSTRACT_PHONE_API_KEY=
# NUMVERIFY_API_KEY=
BUILTWITH_API_KEY=votre-cle-api-builtwith
HIBP_API_KEY=votre-cle-api-hibp

# ============================================
# Google Maps
# ============================================
GOOGLE_MAPS_JS_API_KEY=votre-cle-google-maps-js

# ============================================
# Multicanal - X (Twitter)
# ============================================
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ============================================
# Multicanal - Meta Messenger
# ============================================
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v20.0

# ============================================
# WSL / outils externes
# ============================================
WSL_DISTRO=kali-linux
WSL_USER=loupix
OSINT_TOOL_TIMEOUT=60
PENTEST_TOOL_TIMEOUT=120
# Tests formulaires (Celery, tasks/pentest_tasks.py + services/pentest_analyzer.py)
# PENTEST_FORM_PARALLEL_WORKERS=8
# PENTEST_FORM_HTTP_TIMEOUT=4
# PENTEST_FORM_SQLMAP_PROBE=0
# PENTEST_SQLMAP_FORM_TIMEOUT=90

# ============================================
# Stockage fichiers (uploads / exports)
# ============================================
# Défaut relatif au projet si non défini. En prod Linux souvent :
# UPLOAD_FOLDER=/opt/prospectlab/uploads
# EXPORT_FOLDER=/opt/prospectlab/exports
#
# NFS : même chemin sur l'app et sur tous les workers Celery (voir docs/configuration/DEPLOIEMENT_PRODUCTION.md).
# Les scripts deploy_production / deploy_cluster lisent NFS_SERVER dans .env.prod / .env.cluster
# et montent automatiquement le client si la variable est renseignée.
# NFS_SERVER=node15.lan
# NFS_EXPORT_ROOT=/srv/nfs/prospectlab
# Migration auto si uploads/exports déjà remplis avant le 1er montage (défaut=true si absent).
# NFS_AUTO_STASH=true
# Sur la machine qui héberge aussi les dossiers /srv/nfs/prospectlab : pas de NFS_SERVER,
# mets UPLOAD_FOLDER=/srv/nfs/prospectlab/uploads (et exports). Ou NFS_SKIP_CLIENT_MOUNT=true
# si tu gardes UPLOAD_FOLDER sous /opt/prospectlab avec montage désactivé côté déploiement.
#
# Sur Windows avec workers Linux : sans NFS accessible en écriture depuis le PC, la copie SSH reste utilisée.
# Si le fichier est déjà visible sur les workers au chemin Linux (partage réseau, etc.) :
# CLUSTER_SKIP_WORKER_SCP=true

